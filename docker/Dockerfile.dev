# docker/Dockerfile.dev
FROM python:3.10-slim

# Встановлення системних залежностей для PyQt5 (оновлено для Debian 12)
RUN apt-get update && apt-get install -y \
    libgl1 \
    libglib2.0-0 \
    libx11-xcb1 \
    libxcb-icccm4 \
    libxcb-image0 \
    libxcb-keysyms1 \
    libxcb-randr0 \
    libxcb-render-util0 \
    libxcb-shape0 \
    libxcb-xinerama0 \
    libxcb-xkb1 \
    libxkbcommon-x11-0 \
    libdbus-1-3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Код буде монтуватися через volumes для hot-reloading
CMD ["python", "src/main.py"]